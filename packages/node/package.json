{
  "name": "@hellodword/curl-parser",
  "version": "0.1.0",
  "description": "Curl CLI behavior capture and code generation SDK",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hellodword/curl-parser.git",
    "directory": "packages/node"
  },
  "publishConfig": {
    "@hellodword:registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/node.js",
      "browser": "./dist/browser.js",
      "default": "./dist/node.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./schemas/*": "./schemas/*",
    "./wasm": "./wasm/curl_parser.wasm",
    "./package.json": "./package.json"
  },
  "bin": {
    "curl-parser": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schemas",
    "wasm",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "python ../../scripts/build/build_node_package.py",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:dry-run": "npm run build && npm pack --dry-run"
  }
}
