{
  "schemaVersion": "curl-parser-generator-fixture/v1",
  "target": "js.axios",
  "argv": [
    "curl",
    "--proxy",
    "http://proxy.example:8080",
    "--proxy-user",
    "proxy-user:proxy-pass",
    "-L",
    "--max-redirs",
    "3",
    "--max-time",
    "5",
    "https://example.com"
  ],
  "support": "exact",
  "contains": [
    "requestOptions.proxy = {",
    "protocol: \"http\"",
    "host: \"proxy.example\"",
    "port: 8080",
    "auth: { username: \"REDACTED\", password: \"REDACTED\" }",
    "requestOptions.signal = controller.signal"
  ],
  "notContains": [
    "Proxy-Authorization",
    "headers.authorization",
    "createAxiosProxyAgent"
  ]
}
