{
  "$id": "https://schemas.curl-parser.dev/target-capabilities.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "curl-parser target capabilities v1",
  "type": "object",
  "required": ["schemaVersion", "target", "library", "behaviors"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "curl-target-capabilities/v1"
    },
    "target": {
      "$ref": "generate-input.v1.schema.json#/$defs/target"
    },
    "library": {
      "type": "object",
      "required": ["name", "ecosystem"],
      "properties": {
        "name": {
          "type": "string"
        },
        "ecosystem": {
          "type": "string",
          "enum": ["c", "python", "javascript", "go", "rust"]
        },
        "minimumVersion": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "behaviors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/behaviorCapability"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "capability": {
      "type": "string",
      "enum": [
        "native",
        "lossy",
        "requires-runtime-helper",
        "unsupported"
      ]
    },
    "behaviorCapability": {
      "type": "object",
      "required": ["capability", "message"],
      "properties": {
        "capability": {
          "$ref": "#/$defs/capability"
        },
        "message": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
