{
  "$id": "https://example.invalid/schemas/runtime-profile.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "curl-parser runtime profile",
  "type": "object",
  "required": ["curlVersion", "protocols", "features"],
  "properties": {
    "curlVersion": {
      "type": "string"
    },
    "protocols": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9+.-]*$"
      },
      "uniqueItems": true
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "compile": {
      "type": "object",
      "properties": {
        "availableOptions": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          ]
        },
        "disabledOptions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "defines": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
