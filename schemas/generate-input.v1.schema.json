{
  "$id": "https://schemas.curl-parser.dev/generate-input.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "curl-parser generate input v1",
  "type": "object",
  "required": ["schemaVersion", "target", "ir"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "curl-generate-input/v1"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "ir": {
      "$ref": "curl-ir.v1.schema.json"
    },
    "options": {
      "type": "object",
      "properties": {
        "secretMode": {
          "type": "string",
          "enum": ["redact", "env-ref", "preserve"]
        },
        "runtimeHelpers": {
          "type": "string",
          "enum": ["allow", "inline", "forbid"]
        },
        "format": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "target": {
      "type": "string",
      "enum": [
        "c.libcurl",
        "python.requests",
        "js.fetch",
        "js.undici",
        "go.net_http",
        "rust.reqwest"
      ]
    }
  }
}
